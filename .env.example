# SynthFlux MCP — single OpenAI-compatible media endpoint.
# Configure in Claude Desktop / Cursor / Cline / Codex / Claude Code as:
#   env: { SYNTHFLUX_API_KEY: "...", SYNTHFLUX_BASE_URL: "...", ... }

# Required: API key (Bearer)
SYNTHFLUX_API_KEY=sk-xxx

# Required: upstream base URL.
#   Agnes:    https://apihub.agnes-ai.com
#   StepFun:  https://api.stepfun.ai
#   Your router / SaaS: https://api.your-host.com
SYNTHFLUX_BASE_URL=https://apihub.agnes-ai.com

# Optional: default model ids (override per tool call)
SYNTHFLUX_IMAGE_MODEL=agnes-image-2.1-flash
SYNTHFLUX_TTS_MODEL=step-tts-2
SYNTHFLUX_TTS_VOICE=lively-girl
SYNTHFLUX_VIDEO_MODEL=agnes-video-v2.0
